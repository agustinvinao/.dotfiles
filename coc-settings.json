{
  "coc.preferences.formatOnSaveFiletypes": [
    "javascript",
    "typescript",
    "typescriptreact",
    "json",
    "javascriptreact",
    "sol",
    "solidity",
    "typescript.tsx"
  ],
  "eslint.probe": [
    "javascript",
    "javascriptreact",
    "html",
    "markdown",
    "sol",
    "solidity",
    "typescript",
    "typescriptreact"
  ],
  "eslint.autoFixOnSave": true,
  "eslint.packageManager": "yarn",
  "eslint.run": "onSave",
  "diagnostic.errorSign": "•",
  "diagnostic.warningSign": "•",
  "diagnostic.infoSign": "•",
  "diagnostic.displayByAle": true,
  "prettier.singleQuote": true,
  "languageserver": {
    "solidity": {
      "command": "solc",
      "args": ["--lsp"],
      "trace.server": "verbose",
      "rootPatterns": [".git/"],
      "filetypes": ["solidity", "sol"]
    }
  },
  "suggest.maxCompleteItemCount": 20
}
